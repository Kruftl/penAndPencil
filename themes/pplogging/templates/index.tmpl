{% extends 'base.tmpl' %}

{% block content %}
{% for post in posts %}
<article class="post">
    <header class="post-header">
        <h1><a href="{{ post.permalink() }}">{{ post.title()|e }}</a></h1>
        {% if post.meta('category') == 'tagebuch' %}
            <time datetime="{{ post.date.isoformat() }}">{{ post.meta('fantasydate') or post.formatted_date(date_format) }}</time>
        {% endif %}
    </header>
    <div class="post-body">
        {{ post.text(teaser_only=False) }}
    </div>
</article>
<hr>
{% endfor %}

{% if prev_link or next_link %}
<nav class="pagination">
    {% if prev_link %}<a href="{{ prev_link }}">&larr; Ältere Einträge</a>{% endif %}
    {% if next_link %}<a href="{{ next_link }}">Neuere Einträge &rarr;</a>{% endif %}
</nav>
{% endif %}
{% endblock %}
